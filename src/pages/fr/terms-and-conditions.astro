---
import TermsAndConditionsPage from "@modules/termsAndConditions";
import Layout from "Layout.astro";
import { getTemplateConfig } from "utils/config";

const lang = Astro.currentLocale || "en";
const config = getTemplateConfig(lang);
---

<Layout
  {...config}
  seo={config.termsAndConditions?.seo}
>
  <TermsAndConditionsPage client:load config={config} />
</Layout>
